# FluxWork environment variables. Copy to .env.local and fill in.
# Never commit real secrets.

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY, bypasses RLS. Used by the Paddle webhook to
# write subscription state. Never expose to the browser (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=

# ── Paddle Billing (Epic E) ─────────────────────────────────────────────────
# Client-side (safe to expose) — power the overlay checkout.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_PRICE_ID=
NEXT_PUBLIC_PADDLE_ENV=sandbox            # 'sandbox' | 'production'

# Optional: hosted customer-portal URL shown to paid users on /billing.
NEXT_PUBLIC_PADDLE_CUSTOMER_PORTAL_URL=

# Server-side Paddle API key (pdl_sdbx_… sandbox / pdl_live_… live). Used only by
# `npm run paddle:setup` to provision the product/price. Not read at runtime.
PADDLE_API_KEY=

# Server-side — webhook signature verification (Paddle dashboard → Notifications).
PADDLE_WEBHOOK_SECRET=

# ── Invoice PDF conversion (n8n, optional) ──────────────────────────────────
# If unset, invoices ship as .docx only (PDF conversion is best-effort).
N8N_INVOICE_PDF_WEBHOOK_URL=
N8N_WEBHOOK_TOKEN=
N8N_WEBHOOK_HEADER=Authorization
